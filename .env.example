// OMNI-SIGMA 360 - Environment Configuration
// Copy this file to .env.local and fill in your values

// Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

// AI (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key

// Apollo.io (Hunter Engine)
APOLLO_API_KEY=your_apollo_api_key

// WhatsApp (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_verify_token

// Email (Resend)
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM_ADDRESS=noreply@yourdomain.com

// AI Voice (Vapi)
VAPI_API_KEY=your_vapi_api_key

// AI Video (HeyGen)
HEYGEN_API_KEY=your_heygen_api_key

// Calendar (Cal.com)
CALCOM_API_KEY=your_calcom_api_key

// Twilio (SMS fallback)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_number

// Redis (BullMQ)
REDIS_URL=redis://localhost:6379

// Meta Ads
META_ADS_ACCESS_TOKEN=your_meta_ads_token
META_ADS_ACCOUNT_ID=your_ad_account_id

// Google Ads
GOOGLE_ADS_CLIENT_ID=your_google_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_dev_token
GOOGLE_ADS_REFRESH_TOKEN=your_refresh_token

// TikTok Ads
TIKTOK_ADS_ACCESS_TOKEN=your_tiktok_token
TIKTOK_ADS_ADVERTISER_ID=your_advertiser_id
